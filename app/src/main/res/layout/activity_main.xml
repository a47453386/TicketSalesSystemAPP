<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/pixel_bg_dark">

    <LinearLayout
        android:id="@+id/layout_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111111"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="4dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:weightSum="6">

            <Button android:id="@+id/btn_nav_programmes"
                style="@style/PixelIconButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                app:icon="@drawable/ic_programmes" />

            <Button android:id="@+id/btn_nav_news"
                style="@style/PixelIconButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                app:icon="@drawable/ic_news" />

            <Button android:id="@+id/btn_nav_faq"
                style="@style/PixelIconButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                app:icon="@drawable/ic_faq" />

            <Button android:id="@+id/btn_nav_member"
                style="@style/PixelIconButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                app:icon="@drawable/ic_member" />

            <Button android:id="@+id/btn_nav_question"
                style="@style/PixelIconButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                app:icon="@drawable/ic_question" />

            <Button android:id="@+id/btn_nav_login"
                style="@style/PixelIconButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                app:icon="@drawable/ic_login"
                app:iconTint="@color/pixel_yellow" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/pixel_blue"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_status_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#000000"
        android:padding="6dp"
        android:gravity="center">
        <TextView
            android:id="@+id/tv_status_dot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● SYSTEM: ONLINE"
            android:textColor="@color/pixel_blue"
            android:textSize="9sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/content_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_navbar"
        android:layout_above="@id/layout_status_bar"
        android:layout_margin="8dp"
        android:background="@drawable/layer_list"
        android:padding="4dp">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

</RelativeLayout>