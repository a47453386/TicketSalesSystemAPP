<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[ 修改個人資料 ]"
            android:textColor="#FFCC00"
            android:textSize="22sp"
            android:fontFamily="monospace" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#1A1A1A"
            android:padding="15dp"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔒 基本資料 (不可修改)" android:textColor="#00CCFF" android:textSize="12sp" />
            <TextView android:id="@+id/tv_display_name" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="#FFFFFF" android:paddingTop="8dp" />
            <TextView android:id="@+id/tv_display_birthday" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="#FFFFFF" />
            <TextView android:id="@+id/tv_display_id" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="#FFFFFF" />
            <TextView android:id="@+id/tv_display_gender" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="#FFFFFF" />
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⌨️ 聯絡資訊編輯" android:textColor="#FF00CC" android:layout_marginTop="25dp" />

        <EditText android:id="@+id/et_edit_tel" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="手機號碼" android:textColor="#FFFFFF"
            android:layout_marginTop="10dp" android:background="@drawable/pixel_layout_frame_blue" android:padding="12dp"
            android:inputType="phone" android:maxLength="10" />

        <EditText android:id="@+id/et_edit_email" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="電子郵件" android:textColor="#FFFFFF"
            android:layout_marginTop="15dp" android:background="@drawable/pixel_layout_frame_blue" android:padding="12dp"
            android:inputType="textEmailAddress" />

        <EditText android:id="@+id/et_edit_address" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="聯絡地址" android:textColor="#FFFFFF"
            android:layout_marginTop="15dp" android:background="@drawable/pixel_layout_frame_blue" android:padding="12dp"
            android:minLines="2" android:inputType="textPostalAddress" />

        <Button android:id="@+id/btn_save_profile" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="30dp"
            android:text="[ 執行資料更新 ]" android:backgroundTint="#FFCC00" android:textColor="#000000" />

        <ProgressBar
            android:id="@+id/pb_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>